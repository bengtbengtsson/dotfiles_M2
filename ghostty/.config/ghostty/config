font-size = 16

# remove ligatures
font-feature = -liga
font-feature = -calt
font-feature = -dlig

theme = Gruvbox Dark

auto-update = off

mouse-hide-while-typing = true
focus-follows-mouse = true

copy-on-select = clipboard
keybind = shift+enter=text:\n

command = /bin/zsh -c '/opt/homebrew/bin/tmux new-session -A -s main; exec /bin/zsh'
